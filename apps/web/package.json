{
  "name": "@aviasurveil360/web",
  "version": "0.1.0-candidate",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:demo": "AVIA_BUILD_PROFILE=demo vite",
    "dev:http": "AVIA_BUILD_PROFILE=http vite",
    "build:demo": "tsc -b && AVIA_BUILD_PROFILE=demo vite build",
    "build:http": "tsc -b && AVIA_HTTP_TEST_PROFILE= AVIA_BUILD_PROFILE=http vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:contract:http": "vitest run --config vitest.http.config.ts",
    "test:e2e:mock": "AVIA_E2E_PROFILE=mock playwright test --project=mock",
    "test:e2e:visible-actions": "AVIA_E2E_PROFILE=mock playwright test tests/e2e/visible-action-contract.spec.ts --project=mock",
    "test:e2e:http": "AVIA_E2E_PROFILE=http playwright test --project=http",
    "test:e2e:oidc": "AVIA_E2E_PROFILE=oidc playwright test --project=oidc",
    "test:e2e:offline": "npm run build:demo && AVIA_E2E_PROFILE=offline playwright test --project=offline",
    "test:e2e:brand-offline": "npm run build:demo && AVIA_E2E_PROFILE=offline playwright test tests/e2e/brand-app-shell-restart.spec.ts --project=offline",
    "test:e2e:visual-parity": "AVIA_E2E_PROFILE=visual-parity playwright test --project=legacy-parity",
    "visual:baseline:update": "AVIA_E2E_PROFILE=visual-parity AVIA_UPDATE_LEGACY_BASELINES=1 playwright test --project=legacy-baseline-update",
    "check:app-shell": "node scripts/assert-app-shell-artifact.mjs dist/demo && node scripts/assert-app-shell-artifact.mjs dist/http",
    "contracts:check": "../../scripts/check-contracts.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.3",
    "dexie": "4.4.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "fake-indexeddb": "6.2.5",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "playwright": "1.61.1",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@redocly/openapi-core": {
      "js-yaml": "4.3.0"
    }
  }
}
